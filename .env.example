# Bu dosyayı .env olarak kopyalayıp değerleri doldurun (cp .env.example .env).
# .env git'e gönderilmez; .env.example şablon olarak repoda tutulur.

# PostgreSQL
POSTGRES_USER=basekit
POSTGRES_PASSWORD=basekit_dev_pw
POSTGRES_DB=basekit
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=basekit
RABBITMQ_PASSWORD=basekit_dev_pw
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# MinIO (S3 uyumlu nesne deposu)
MINIO_ROOT_USER=basekit
MINIO_ROOT_PASSWORD=basekit_dev_pw
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
